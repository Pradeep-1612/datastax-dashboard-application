{
  "name": "datastax-dashboard-bff",
  "version": "1.0.0",
  "description": "TypeScript Express BFF for DataStax dashboard",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "build:spa": "cd ../datastax-dashboard-spa && npm run build",
    "build:all": "npm run build:spa && npm run build",
    "start": "node dist/server.js",
    "package": "pkg . --compress GZip --output release/DataOnTheHouse",
    "package:all": "npm run build:all && npm run package"
  },
  "keywords": [
    "bff",
    "typescript",
    "express",
    "axios"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.18.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "pkg": "^5.8.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "pkg": {
    "assets": [
      "../datastax-dashboard-spa/dist/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ],
    "outputPath": "release"
  }
}
